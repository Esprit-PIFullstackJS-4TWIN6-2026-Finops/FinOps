# API
PORT=3000

# Database — MySQL 8 (required). Create DB_NAME first. If sync fails on FK, see backend/sql/fix-orphan-expense-created-by.sql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=finops_saas

# JWT (change in production)
JWT_SECRET=finops-secret-key-change-in-prod

# Mail — Real Gmail delivery (smtp.gmail.com:587, TLS)
# Enable 2-Step Verification, then create an App Password at:
# https://myaccount.google.com/apppasswords
# Paste the 16 characters into GMAIL_APP_PASSWORD (not your normal Gmail password).
MAIL_PROVIDER=gmail
MAIL_DISABLE_ETHEREAL=true
GMAIL_USER=your-account@gmail.com
GMAIL_APP_PASSWORD=your-16-char-google-app-password
MAIL_FROM="FinOps Platform <your-account@gmail.com>"

# Frontend URL used in email links
APP_URL=http://localhost:5173

# Google Gemini (optional — assistant IA / catégorisation ; sans clé, réponses déterministes)
# GEMINI_API_KEY=
# API_KEY=   # alias accepté par le backend

# Invoice Ninja v5 (optional — leave empty to disable sync)
# Base URL only, e.g. https://your-domain.invoicing.co (no trailing slash)
INVOICE_NINJA_BASE_URL=
INVOICE_NINJA_API_TOKEN=
# Optional default X-Company-Id if not set per FinOps company (PUT /companies/:id)
# INVOICE_NINJA_COMPANY_ID=
# Optional: HTTP retries for 5xx/429 (default 3)
# INVOICE_NINJA_MAX_RETRIES=3
