# API
PORT=3000

# Database — easiest local setup (no MySQL required)
DB_TYPE=sqlite
DB_SQLITE_PATH=./data/finops.db

# MySQL — use when you have a running MySQL server and created DB_NAME
# DB_TYPE=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=finops_saas

# Mail
# Use Gmail SMTP for real email delivery
MAIL_PROVIDER=gmail
MAIL_DISABLE_ETHEREAL=true
GMAIL_USER=your-address@gmail.com
GMAIL_APP_PASSWORD=your-16-char-google-app-password
MAIL_FROM="FinOps Platform <your-address@gmail.com>"

# Optional generic SMTP fallback
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_SECURE=false
# MAIL_USER=your-address@gmail.com
# MAIL_PASS=your-16-char-google-app-password
